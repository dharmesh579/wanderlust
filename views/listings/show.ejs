<% layout("/layouts/boilerplate") %>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-3">
      <h3><b><%=listing.title%></b></h3>
    </div>

    <div class="card col-6 offset-3">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="<%= listing.image.filename %>"
      />
      <div class="card-body">
        <p class="card-text">
          <br />
          <%=listing.description%> <br />
          <span class="text-success fw-bold"
            >&#8377; <%=listing.price.toLocaleString("en-In")%></span
          >
          / Night<br />
          <i class="fa-solid fa-location-dot"></i><%=listing.location%>,
          <%=listing.country%>
        </p>
      </div>
    </div>
    <div class="col-3 offset-3 mb-3">
      <div class="d-flex gap-2 align-items-center">
        <a class="btn btn-outline-dark" href="http://localhost:6500/listings"
          >Home Page</a
        >
        <a
          class="btn btn-outline-dark"
          href="/listings/<%= listing._id %>/edit?_method="
          >Edit Page</a
        >
        <form
          class="d-inline"
          action="/listings/<%= listing._id %>?_method=DELETE"
          method="post"
        >
          <button class="btn btn-outline-danger">Delete Listing</button>
        </form>
      </div>
    </div>
  </div>
</body>
