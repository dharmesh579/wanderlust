<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><b><%=listing.title%></b></h3>
  </div>

  <div class="card col-6 offset-3 listing-card">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="<%= listing.image.filename %>"
    />
    <div class="card-body">
      <p class="card-text">
        Owned by
        <i><%=listing.owner.username%></i></p>
       <p class="card-text"> <%=listing.description%></p> 
       <p class="card-text"><span class="text-success fw-bold"
          >&#8377; <%=listing.price.toLocaleString("en-In")%></span>/ Night</p>
        <p class="card-text"><i class="fa-solid fa-location-dot"></i><%=listing.location%>,</p>
        
        <p class="card-text"><%=listing.country%></p>
        
      
    </div>
  </div>
  <div class="col-3 offset-3 mb-3">
    <div class="d-flex gap-2 align-items-center">
      <a class="btn btn-outline-dark" href="/listings"
        >Home Page</a
      >
      <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
      <a
        class="btn btn-outline-dark"
        href="/listings/<%= listing._id %>/edit"
        >Edit Page</a
      >
      <form
        class="d-inline"
        action="/listings/<%= listing._id %>?_method=DELETE"
        method="post"
      >
        <button class="btn btn-outline-danger">Delete Listing</button>
      </form>
      <% } %>
    </div>
  </div>

   
  <div class="col-8 offset-3 mb-3">
    <hr />
     <% if(currUser){ %>
    <h4>Leave a Review</h4>
    <form
      action="/listings/<%= listing._id %>/reviews"
      method="post"
      novalidate
      class="needs-validation"
    >
      <div class="mb-3 mt-3">
        <label class="form-label" for="rating">Rating</label>
        <input
          type="range"
          min="1"
          max="5"
          id="rating"
          name="review[rating]"
          class="form-range"
        />
      </div>
      <div class="mb-3 mt-3">
        <label class="form-label" for="comment">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          cols="30"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please submit some comment</div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>
     <hr />
    <% } %>
   

    <p><b>All Reviews</b></p>
    <div class="row">
    <% for(review of listing.reviews){ %>
      <div class="card col-5 ms-3 mb-3
      ">
        <div class="card-body">
          <div class="card-title">
            <%= review.author.user %>
          </div>
          <div class="card-text">
            <%= review.comment %>
          </div>
          <div class="card-text">
            <%= review.rating %> stars
          </div>
        </div>
        <form action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" class="mb-3" method="post">
          <button class="btn btn-dark">
            Delete
          </button>
        </form>
      </div>
    <%}%>
    </div>
  </div>
</div>
